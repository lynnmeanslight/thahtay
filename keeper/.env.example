# Private key of the keeper wallet (0x-prefixed)
# This wallet must hold some ETH for gas on Unichain Sepolia
PRIVATE_KEY=0x...

# Deployed PriceKeeper contract address (output of DeployPriceKeeper.s.sol)
PRICE_KEEPER_ADDRESS=0x...

# Unichain Sepolia RPC (default shown — override if using a private endpoint)
RPC_URL=https://unichain-sepolia.g.alchemy.com/v2/YMzKKvdFJU9ZBB0r2yGuo

# ThaHtayHook address (already deployed — don't change unless redeployed)
HOOK_ADDRESS=0xeb5851c6014C5a5F5A062C1331826b0789C3F0C0

# Deployed protocol contract addresses (used for diagnostics/scripts)
FUNDING_RATE_MANAGER_ADDRESS=0x723Bb79a7951415563129eE3583e573432aD6Fda
LIQUIDATION_ENGINE_ADDRESS=0x4503A9d28Dc625676e327184Ea76c654Dd657419
POSITION_MANAGER_ADDRESS=0x2071faEe2ee61fb5a295BF03a1D51f26D2F9FaBD

# Token and infra addresses
USDC_ADDRESS=0x31d0220469e10c4E71834a79b1f276d740d3768F
WETH_ADDRESS=0x4200000000000000000000000000000000000006
POOL_MANAGER_ADDRESS=0x00B036B58a818B1BC34d502D3fE730Db729e62AC

# How often to check the price (milliseconds). Default: 60000 (1 min)
# Use 15000 for more responsive demo behaviour
POLL_INTERVAL_MS=60000

# Optional: deployed Uniswap v4 StateView contract for pool-specific reads
# If set, pool-state-check.mjs can read exact pool liquidity via getLiquidity(poolId)
STATE_VIEW_ADDRESS=0x...
